{
  "name": "context-bridge",
  "displayName": "Context Bridge",
  "description": "Cross-repository memory/context bridge that captures architecture and business context from one repo and applies it to another.",
  "version": "0.1.0",
  "publisher": "context-bridge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/apt-get2Update/vs-code-context-bridge.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "context",
    "bridge",
    "cursor",
    "rules",
    "architecture",
    "cross-repo"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "contextBridge.captureContext",
        "title": "Context Bridge: Capture Current Project Context"
      },
      {
        "command": "contextBridge.suggestContext",
        "title": "Context Bridge: Suggest Context For This Repository"
      },
      {
        "command": "contextBridge.applyContext",
        "title": "Context Bridge: Apply Suggested Context"
      },
      {
        "command": "contextBridge.openStore",
        "title": "Context Bridge: Open Context Store"
      },
      {
        "command": "contextBridge.validateContext",
        "title": "Context Bridge: Validate Context Files"
      }
    ],
    "configuration": {
      "title": "Context Bridge",
      "properties": {
        "contextBridge.storePath": {
          "type": "string",
          "default": "",
          "description": "Custom path for the context store file. Leave empty for default (~/.context-bridge/store.json)."
        },
        "contextBridge.maxSuggestions": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 20,
          "description": "Maximum number of context suggestions to return."
        },
        "contextBridge.minimumConfidence": {
          "type": "number",
          "default": 0.3,
          "minimum": 0,
          "maximum": 1,
          "description": "Minimum confidence score (0-1) for context suggestions."
        },
        "contextBridge.captureReadme": {
          "type": "boolean",
          "default": true,
          "description": "Include README.md in context capture."
        },
        "contextBridge.captureAgentsMd": {
          "type": "boolean",
          "default": true,
          "description": "Include AGENTS.md in context capture."
        },
        "contextBridge.autoValidate": {
          "type": "boolean",
          "default": true,
          "description": "Automatically validate context files after apply."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src test --ext .ts",
    "lint:fix": "eslint src test --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "node ./out/test/runner.js",
    "pretest": "npm run compile",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/sinon": "^17.0.3",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "glob": "^10.3.10",
    "mocha": "^10.3.0",
    "prettier": "^3.2.0",
    "sinon": "^17.0.1",
    "typescript": "^5.3.3",
    "@vscode/vsce": "^2.22.0",
    "@vscode/test-electron": "^2.3.8"
  }
}
